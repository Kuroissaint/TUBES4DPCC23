pipeline {
    agent any

    environment {
        SERVICE_NAME = "communication-service" 
        DOCKER_IMAGE = "kelcloud23/${SERVICE_NAME}:${env.BUILD_NUMBER}"
    }

    stages {
        stage('1. Checkout Repo') {
            steps {
                checkout scm
            }
        }

        stage('2. Unit Tests') {
            steps {
                // Masuk ke folder service sebelum testing
                dir('communication-service') {
                    bat 'go test ./... -v'
                }
            }
        }

        stage('3. Lint / Vet') {
            steps {
                dir('communication-service') {
                    bat 'go vet ./...'
                }
            }
        }

        stage('4. Build Image (Lokal)') {
            steps {
                // Masuk ke folder service karena Dockerfile ada di sini
                dir('communication-service') {
                    bat "docker build -t ${DOCKER_IMAGE} ."
                }
            }
        }

        stage('5. Functional Tests') {
            steps {
                dir('communication-service') {
                    bat 'go test -tags=functional ./... -v'
                }
            }
        }

        stage('6. Push Image') {
            steps {
                // Push image tidak butuh masuk folder
                bat "docker push ${DOCKER_IMAGE}"
                bat "docker tag ${DOCKER_IMAGE} kelcloud23/${SERVICE_NAME}:latest"
                bat "docker push kelcloud23/${SERVICE_NAME}:latest"
            }
        }

        stage('7. Deploy di Kubernetes') {
            steps {
                // Masuk ke folder service karena folder k8s/ ada di sini
                dir('communication-service') {
                    bat "kubectl apply -f k8s/"
                }
                bat "kubectl rollout restart deployment/${SERVICE_NAME}"
            }
        }

        stage('8. Verify') {
            steps {
                bat "kubectl rollout status deployment/${SERVICE_NAME}"
                bat "kubectl get pods -l app=${SERVICE_NAME}"
            }
        }
    }

    post {
        success {
            echo "Successfully deployed ${SERVICE_NAME} version ${env.BUILD_NUMBER}"
        }
        failure {
            echo "Deployment failed! Check logs."
        }
    }
}