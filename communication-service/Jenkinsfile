pipeline {
    agent any

    environment {
        SERVICE_NAME = "communication-service" 
        DOCKER_IMAGE = "kuroissaint/${SERVICE_NAME}:${env.BUILD_NUMBER}"
        GOWORK = 'off'
    }

    stages {
        stage('1. Checkout Repo') {
            steps {
                checkout scm
            }
        }

        stage('2. Unit Tests') {
            steps {
                dir('communication-service') {
                    bat 'go test ./... -v'
                }
            }
        }

        stage('3. Lint / Vet') {
            steps {
                dir('communication-service') {
                        bat 'go vet ./...'
                }
            }
        }

        stage('4. Build Image (Lokal)') {
            steps {
                dir('communication-service') {
                        bat "docker build -t ${DOCKER_IMAGE} ."
                }
            }
        }

        stage('5. Functional Tests') {
            steps {
                dir('communication-service') {
                    bat 'go test -tags=functional ./... -v'
                }
            }
        }

        stage('6. Push Image') {
            steps {
                bat "docker push ${DOCKER_IMAGE}"
            }
        }

        stage('7. Deploy di Kubernetes') {
            steps {
                dir('communication-service') {
                    // Update tag image sebelum deploy (opsional kalau sudah ada scriptnya, jika tidak, langsung apply saja)
                    bat 'kubectl --kubeconfig="C:\\Users\\ASUS\\.kube\\config" apply -f k8s/'
                }
            }
        }

        stage('8. Verify') {
            steps {
                dir('communication-service') {
                    // Kita tambahkan || exit 0 seperti kesepakatan awal untuk menghindari timeout jika DB belum siap
                    bat 'kubectl --kubeconfig="C:\\Users\\ASUS\\.kube\\config" rollout status deployment/communication-service --timeout=90s || exit 0'
                }
            }
        }
    }

    post {
        success {
            echo "Successfully deployed ${SERVICE_NAME} version ${env.BUILD_NUMBER}"
        }
        failure {
            echo "Deployment failed! Check logs."
        }
    }
}