pipeline {
    agent any

    environment {
        SERVICE_NAME = "pricing-service"
        DOCKER_IMAGE = "kelcloud23/${SERVICE_NAME}:${env.BUILD_NUMBER}"
    }

    stages {
        stage('1. Checkout Repo') {
            steps {
                checkout scm
            }
        }

        stage('2. Unit Tests') {
            steps {
                dir('pricing-service') {
                    bat '''
                        set GOWORK=off
                        go test ./... -v
                    '''
                }
            }
        }

        stage('3. Lint / Vet') {
            steps {
                dir('pricing-service') {
                    bat '''
                        set GOWORK=off
                        go vet ./...
                    '''
                }
            }
        }

        stage('4. Build Image (Lokal)') {
            steps {
                dir('pricing-service') {
                    bat "docker build -t ${DOCKER_IMAGE} ."
                }
            }
        }

        stage('5. Functional Tests') {
            steps {
                dir('pricing-service') {
                    bat '''
                        set GOWORK=off
                        go test -tags=functional ./... -v
                    '''
                }
            }
        }

        stage('6. Push Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-login', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                    bat '''
                        docker login -u %DOCKER_USER% -p %DOCKER_PASS%
                        docker push ''' + DOCKER_IMAGE
                }
            }
        }

        stage('7. Deploy di Kubernetes') {
            steps {
                dir('pricing-service') {
                    withCredentials([file(credentialsId: 'k8s-config', variable: 'KUBECONFIG_TMP')]) {
                        bat """
                            kubectl --kubeconfig="%KUBECONFIG_TMP%" apply -f k8s/
                            kubectl --kubeconfig="%KUBECONFIG_TMP%" set image deployment/${SERVICE_NAME} ${SERVICE_NAME}=${DOCKER_IMAGE}
                        """
                    }
                }
            }
        }

        stage('8. Verify') {
            steps {
                dir('pricing-service') {
                    withCredentials([file(credentialsId: 'k8s-config', variable: 'KUBECONFIG_TMP')]) {
                        // 1. Cek status pod (Apakah CrashLoopBackOff, Error, dll)
                        bat 'kubectl --kubeconfig="%KUBECONFIG_TMP%" get pods -l app=pricing-service'
                        
                        // 2. Cek event deployment untuk melihat pesan error dari Kubernetes
                        bat 'kubectl --kubeconfig="%KUBECONFIG_TMP%" describe deployment pricing-service'

                        // 3. Perintah aslimu (yang bikin timeout)
                        bat 'kubectl --kubeconfig="%KUBECONFIG_TMP%" rollout status deployment/pricing-service --timeout=60s'
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Successfully deployed ${SERVICE_NAME} version ${env.BUILD_NUMBER}"
        }
        failure {
            echo "Deployment failed! Check logs."
        }
    }
}