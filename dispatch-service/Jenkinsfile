pipeline {
    agent any

    tools {
        // Mengarahkan Jenkins agar menggunakan nama konfigurasi Go yang tadi kita buat
        go 'go-1.21'
    }

    stages {
        stage('1. Checkout Repo') {
            steps {
                echo 'Repository checked out successfully.'
            }
        }

        stage('2. Unit Tests') {
            steps {
                dir('dispatch-service') {
                    sh 'go test ./... -v'
                }
            }
        }

        stage('3. Lint/Vet') {
            steps {
                dir('dispatch-service') {
                    sh 'go vet ./...'
                }
            }
        }

        stage('4. Build Image') {
            steps {
                dir('dispatch-service') {
                    sh 'docker build -t dispatch-service:latest .'
                }
            }
        }

        stage('5. Functional Tests') {
            steps {
                dir('dispatch-service') {
                    sh 'go test -tags=functional ./... -v'
                }
            }
        }

        stage('6. Push Image') {
            steps {
                echo 'Skipping push image for local development...'
                // sh 'docker push dispatch-service:latest'
            }
        }

        stage('7. Deploy di Kubernetes') {
            steps {
                dir('dispatch-service') {
                    sh 'kubectl apply -f k8s/'
                }
            }
        }

        stage('8. Verify') {
            steps {
                sh 'kubectl rollout status deployment/dispatch-service'
            }
        }
    }
}