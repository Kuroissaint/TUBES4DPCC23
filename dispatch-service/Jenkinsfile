pipeline {
    agent any

    tools {
        go 'go-1.21' 
    }

    environment {
        SERVICE_NAME = "dispatch-service"
        DOCKER_IMAGE = "drikz/${SERVICE_NAME}:${env.BUILD_NUMBER}"
    }

    stages {
        stage('1. Checkout Repo') {
            steps {
                checkout scm
            }
        }

        stage('2. Unit Tests') {
            steps {
                dir("${SERVICE_NAME}") {
                    sh 'GOWORK=off go test -v ./... -skip Functional' 
                }
            }
        }

        stage('3. Lint/Vet') {
            steps {
                dir("${SERVICE_NAME}") {
                    sh 'GOWORK=off go vet ./...'
                }
            }
        }

        stage('4. Build & Push Image') {
            steps {
                dir("${SERVICE_NAME}") {
                    sh "docker build -t ${DOCKER_IMAGE} ."
                    
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-login', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                        sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
                        sh "docker push ${DOCKER_IMAGE}"
                    }
                }
            }
        }

        stage('5. Functional Tests') {
            steps {
                dir("${SERVICE_NAME}") {
                    sh 'GOWORK=off go test -v -run Functional ./... || exit 0'
                }
            }
        }

        stage('6. Deploy & Verify K8s') {
            steps {
                dir("${SERVICE_NAME}") {
                    sh "sed -i 's|my-registry/${SERVICE_NAME}:latest|${DOCKER_IMAGE}|g' k8s/deployment.yaml"
                    
                    withCredentials([file(credentialsId: 'k8s-config', variable: 'KUBECONFIG_TMP')]) {
                        // KUNCINYA DI SINI: Salin config ke tempat kerja, lalu paksa ubah 127.0.0.1 menjadi host.docker.internal
                        sh 'cp $KUBECONFIG_TMP ./kubeconfig_local'
                        sh 'sed -i "s|127.0.0.1|host.docker.internal|g" ./kubeconfig_local'
                        
                        // Eksekusi apply menggunakan config local yang jalurnya sudah dialihkan ke laptop Windows lu
                        sh "kubectl --kubeconfig=./kubeconfig_local apply -f k8s/ --validate=false"
                        sh "kubectl --kubeconfig=./kubeconfig_local rollout status deployment/dispatch-service --timeout=90s"
                    }
                }
            }
        }
    }

    post {
        always {
            echo "Pipeline untuk ${SERVICE_NAME} selesai dieksekusi."
        }
    }
}