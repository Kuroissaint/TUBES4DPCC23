pipeline {
    agent any

    tools {
        go 'go-1.21'
    }

    stages {
        stage('1. Checkout Repo') {
            steps {
                echo 'Repository checked out successfully.'
            }
        }

        stage('2. Unit Tests') {
            steps {
                dir('dispatch-service') {
                    sh 'GOWORK=off go test ./... -v'
                }
            }
        }

        stage('3. Lint/Vet') {
            steps {
                dir('dispatch-service') {
                    sh 'GOWORK=off go vet ./...'
                }
            }
        }

        stage('4. Build Image') {
            steps {
                dir('dispatch-service') {
                    sh 'docker build -t dispatch-service:latest .'
                }
            }
        }

        stage('5. Functional Tests') {
            steps {
                dir('dispatch-service') {
                    // Karena tidak di-skip, Jenkins akan mengeksekusi tes ini.
                    // Jika database belum menyala di laptopmu, stage ini akan gagal (merah).
                    sh 'GOWORK=off go test -tags=functional ./... -v'
                }
            }
        }

        stage('6. Push Image') {
            steps {
                echo 'Skipping push image for local development...'
            }
        }

        stage('7. Deploy di Kubernetes') {
            steps {
                dir('dispatch-service') {
                    sh 'kubectl apply -f k8s/'
                }
            }
        }

        stage('8. Verify') {
            steps {
                sh 'kubectl rollout status deployment/dispatch-service'
            }
        }
    }
}